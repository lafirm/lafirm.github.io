---
import { projectsData } from '../data/projects';

interface Props {
  id?: string;
}

const { id = 'projects' } = Astro.props;
---

<section id={id} class="section-spacing border-t border-card-border bg-card-bg bg-opacity-30">
  <div class="container-wide">
    <div class="max-w-5xl mx-auto">
      <!-- Section Header -->
      <div class="mb-16">
        <span class="badge mb-4 inline-block">Featured Projects</span>
        <h2 class="heading-lg">
          Engineering <span class="text-accent">Case Studies</span>
        </h2>
        <p class="text-xl text-text-secondary mt-4 max-w-2xl">
          Deep dives into problems solved, architecture designed, and lessons learned.
        </p>
      </div>

      <!-- Projects Grid -->
      <div class="space-y-8">
        {
          projectsData.map((project, index) => (
            <div class="card group hover:border-accent transition-colors">
              {/* Header */}
              <div class="mb-6">
                <div class="flex items-start justify-between mb-3">
                  <div>
                    <h3 class="text-2xl font-bold text-text-primary group-hover:text-accent transition-colors">
                      {project.title}
                    </h3>
                    <p class="text-accent font-semibold mt-1">{project.company}</p>
                  </div>
                  <span class="px-3 py-1 bg-accent bg-opacity-10 text-accent rounded-full text-xs font-semibold whitespace-nowrap">
                    Project {index + 1}
                  </span>
                </div>
                <p class="text-text-secondary">{project.description}</p>
              </div>

              {/* Content Grid */}
              <div class="grid md:grid-cols-2 gap-6 mb-6 pb-6 border-b border-card-border">
                <div>
                  <h4 class="text-sm font-semibold text-text-tertiary uppercase tracking-wide mb-2">
                    Problem
                  </h4>
                  <p class="text-text-secondary text-sm leading-relaxed">{project.problem}</p>
                </div>
                <div>
                  <h4 class="text-sm font-semibold text-text-tertiary uppercase tracking-wide mb-2">
                    Architecture
                  </h4>
                  <p class="text-text-secondary text-sm leading-relaxed">{project.architecture}</p>
                </div>
                <div>
                  <h4 class="text-sm font-semibold text-text-tertiary uppercase tracking-wide mb-2">
                    Approach
                  </h4>
                  <p class="text-text-secondary text-sm leading-relaxed">{project.approach}</p>
                </div>
                <div>
                  <h4 class="text-sm font-semibold text-text-tertiary uppercase tracking-wide mb-2">
                    Challenges
                  </h4>
                  <p class="text-text-secondary text-sm leading-relaxed">{project.challenges}</p>
                </div>
              </div>

              {/* Results */}
              <div class="mb-6">
                <h4 class="text-sm font-semibold text-success uppercase tracking-wide mb-3">
                  Results
                </h4>
                <div class="space-y-2">
                  {project.results.map((result) => (
                    <div class="flex items-start gap-2">
                      <span class="text-success mt-1 text-lg">✓</span>
                      <span class="text-text-secondary text-sm">{result}</span>
                    </div>
                  ))}
                </div>
              </div>

              {/* Lesson Learned */}
              <div class="mb-6 p-4 bg-card-bg bg-opacity-50 border-l-2 border-accent rounded-lg">
                <p class="text-xs font-semibold text-accent uppercase tracking-wide mb-2">
                  Lesson Learned
                </p>
                <p class="text-text-secondary text-sm leading-relaxed">{project.lessonLearned}</p>
              </div>

              {/* Technologies */}
              <div class="pt-4 border-t border-card-border">
                <p class="text-xs font-semibold text-text-tertiary uppercase tracking-wide mb-3">
                  Tech Stack
                </p>
                <div class="flex flex-wrap gap-2">
                  {project.technologies.map((tech) => (
                    <span class="px-3 py-1 bg-accent bg-opacity-10 text-accent rounded-full text-xs font-medium">
                      {tech}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
