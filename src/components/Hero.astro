---
import { profileData } from '../data/profile';

interface Props {
  id?: string;
}

const { id = 'home' } = Astro.props;
---

<section id={id} class="min-h-screen flex items-center justify-center pt-20 pb-20">
  <div class="container-wide">
    <div class="max-w-4xl mx-auto text-center animate-fade-in">
      <!-- Badge -->
      <div class="mb-8 flex justify-center">
        <span class="badge">Senior Software Development Engineer</span>
      </div>

      <!-- Main Headline -->
      <h1 class="heading-xl mb-6 leading-tight">
        Building Reliable <span class="text-accent">Data Platforms</span>
        <br />
        That Scale
      </h1>

      <!-- Subheading -->
      <p class="text-xl text-text-secondary mb-12 max-w-2xl mx-auto leading-relaxed">
        Senior Software Development Engineer with expertise in modern data platforms, cloud-native infrastructure, and platform engineering. Specializing in building systems that are scalable, observable, and maintainable.
      </p>

      <!-- CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 justify-center mb-16">
        <a href="#contact" class="button-primary">Get in Touch</a>
        <a
          href={profileData.social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="button-secondary"
        >
          View GitHub
        </a>
        <a
          href={profileData.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="button-secondary"
        >
          LinkedIn Profile
        </a>
      </div>

      <!-- Hero Image / Visual -->
      <div class="relative h-96 rounded-2xl overflow-hidden border border-card-border bg-card-bg">
        <div class="absolute inset-0 bg-gradient-to-br from-accent via-transparent to-success opacity-10"></div>
        <div class="absolute inset-0">
          <div class="grid grid-cols-3 gap-4 w-full h-full p-8" style="grid-auto-rows: 1fr">
            <!-- Animated background elements -->
            <div class="rounded-lg bg-card-border bg-opacity-30 animate-pulse" style="animation-delay: 0ms"></div>
            <div class="rounded-lg bg-card-border bg-opacity-50 animate-pulse" style="animation-delay: 100ms"></div>
            <div class="rounded-lg bg-card-border bg-opacity-30 animate-pulse" style="animation-delay: 200ms"></div>
            <div class="rounded-lg bg-card-border bg-opacity-40 animate-pulse" style="animation-delay: 300ms"></div>
            <div class="rounded-lg bg-accent bg-opacity-20 animate-pulse" style="animation-delay: 100ms"></div>
            <div class="rounded-lg bg-card-border bg-opacity-40 animate-pulse" style="animation-delay: 0ms"></div>
            <div class="rounded-lg bg-card-border bg-opacity-30 animate-pulse" style="animation-delay: 200ms"></div>
            <div class="rounded-lg bg-card-border bg-opacity-50 animate-pulse" style="animation-delay: 100ms"></div>
            <div class="rounded-lg bg-success bg-opacity-20 animate-pulse" style="animation-delay: 200ms"></div>
          </div>
        </div>
      </div>

      <!-- Scroll Indicator -->
      <div class="mt-16 flex justify-center animate-bounce">
        <svg
          class="w-6 h-6 text-text-secondary"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M19 14l-7 7m0 0l-7-7m7 7V3"
          ></path>
        </svg>
      </div>
    </div>
  </div>
</section>

<style>
  @keyframes pulse {
    0%,
    100% {
      opacity: 0.3;
    }
    50% {
      opacity: 0.8;
    }
  }

  .animate-pulse {
    animation: pulse 4s cubic-bezier(0.4, 0, 0.6, 1) infinite;
  }

  .delay-0 {
    animation-delay: 0s;
  }

  .delay-100 {
    animation-delay: 0.1s;
  }

  .delay-200 {
    animation-delay: 0.2s;
  }

  .delay-300 {
    animation-delay: 0.3s;
  }

  @keyframes bounce {
    0%,
    100% {
      transform: translateY(0);
    }
    50% {
      transform: translateY(-10px);
    }
  }

  .animate-bounce {
    animation: bounce 2s infinite;
  }
</style>
